<?xml version="1.0" encoding="utf-8"?>
<Page
  x:Name="Root"
  x:Class="MTGApplication.Features.DeckEditor.Views.DeckEditorPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="using:CommunityToolkit.WinUI"
  xmlns:controls="using:CommunityToolkit.WinUI.Controls"
  xmlns:sys="using:System"
  xmlns:customControls="using:MTGApplication.General.Views.Controls"
  xmlns:helpers="using:MTGApplication.General.Views.BindingHelpers"
  xmlns:converters1="using:MTGApplication.General.Views.BindingHelpers.Converters"
  xmlns:converters="using:MTGApplication.Features.DeckEditor.Views.Converters"
  xmlns:editorpage="using:MTGApplication.Features.DeckEditor.ViewModels.EditorPage"
  xmlns:cardview="using:MTGApplication.Features.DeckEditor.Views.Controls.CardView" 
  xmlns:cardlistview="using:MTGApplication.Features.DeckEditor.Views.Controls.CardListView" 
  xmlns:deckcard="using:MTGApplication.Features.DeckEditor.ViewModels.DeckCard" 
  xmlns:cardgroup="using:MTGApplication.Features.DeckEditor.ViewModels.DeckCardGroup.CardGroup" 
  xmlns:controls1="using:MTGApplication.Features.DeckEditor.Views.Controls" 
  xmlns:commanderview="using:MTGApplication.Features.DeckEditor.Views.Controls.CommanderView" 
  xmlns:controls2="using:MTGApplication.Features.DeckEditor.Views.Charts.Views.Controls"
  mc:Ignorable="d"
  d:DataContext="{d:DesignInstance Type=editorpage:DeckEditorPageViewModel}"
  Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
  KeyboardAcceleratorPlacementMode="Hidden">

  <Page.Resources>
    <converters:CardColorGroupToBoolConverter x:Key="CardColorGroupToBoolConverter"/>
    <converters1:ToStringToBoolConverter x:Key="ToStringToBoolConverter"/>
    <converters1:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter"/>
  </Page.Resources>
  
  <!--#region Keyboard Accelerators -->
  <!--NOTE: KeyboardAccelerators needs to be here because menu flyout accelerators do not work if the flyout has not been opened-->
  <Page.KeyboardAccelerators>
    <KeyboardAccelerator Key="Z" Modifiers="Control" Invoked="UndoKeyboardAccelerator_Invoked" />
    <KeyboardAccelerator Key="Y" Modifiers="Control" Invoked="RedoKeyboardAccelerator_Invoked" />
    <KeyboardAccelerator Modifiers="Control" Key="S" Invoked="SaveDeckKeyboardAccelerator_Invoked" />
    <KeyboardAccelerator Modifiers="Control" Key="O" Invoked="OpenDeckKeyboardAccelerator_Invoked" />
    <KeyboardAccelerator Modifiers="Control" Key="N" Invoked="NewDeckKeyboardAccelerator_Invoked" />
    <KeyboardAccelerator Key="Escape" Invoked="ResetFiltersKeyboardAccelerator_Invoked" />
  </Page.KeyboardAccelerators>
  <!--#endregion-->

  <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

    <!--#region Visual State Manager -->
    <VisualStateManager.VisualStateGroups>
      <VisualStateGroup x:Name="DeckNameTitleSaveState">
        <!--NOTE: Changes deck name text to "Unsaved", if the deck has no name-->
        <VisualState>
          <VisualState.StateTriggers>
            <ui:IsEqualStateTrigger Value="{x:Bind ViewModel.DeckName, Mode=OneWay}" To="{x:Bind sys:String.Empty}" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="SelectedDeckNameTitle.Text" Value="Unsaved" />
            <Setter Target="SelectedDeckNameTitle.FontStyle" Value="Italic" />
            <Setter Target="SelectedDeckNameTitle.Foreground" Value="LightGray" />
          </VisualState.Setters>
        </VisualState>

        <!--NOTE: Changes deck name text to different color to show that the deck has unsaved changes-->
        <VisualState>
          <VisualState.StateTriggers>
            <ui:IsEqualStateTrigger Value="{x:Bind ViewModel.DeckViewModel.SaveStatus.HasUnsavedChanges, Mode=OneWay}" To="True" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="SelectedDeckNameTitle.Foreground" Value="{ThemeResource SystemAccentColorLight1}" />
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>

      <!--NOTE: Changes filter button color when filters has been applied-->
      <VisualStateGroup x:Name="DeckFilterAppBarButtonState">
        <VisualState>
          <VisualState.StateTriggers>
            <ui:IsEqualStateTrigger Value="{x:Bind ViewModel.DeckViewModel.CardFilter.FiltersApplied, Mode=OneWay}" To="True"/>
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="DeckFilterAppBarButton.Style" Value="{StaticResource PrimaryAppBarButtonStyle}"/>
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>
    </VisualStateManager.VisualStateGroups>
    <!--#endregion-->

    <controls:DockPanel
      LastChildFill="True"
      Margin="0 0 10 10"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

      <!--#region Sidebar -->
      <TabView
        x:Name="SidebarTabs"
        controls:DockPanel.Dock="Right"
        IsAddTabButtonVisible="False"
        Width="250"
        Margin="10 7 0 0"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        BorderThickness="0 2 0 0"
        BorderBrush="{ThemeResource RegionColor}"
        AllowDropTabs="False"
        CanDragTabs="False"
        CanReorderTabs="False">
        <TabView.Resources>
          <!-- NOTE: Disables entrance transitions -->
          <Style TargetType="TabViewListView">
            <Setter Property="ItemContainerTransitions">
              <Setter.Value>
                <TransitionCollection />
              </Setter.Value>
            </Setter>
          </Style>
        </TabView.Resources>
        <TabViewItem Header="Side lists" IsClosable="False">

          <!--#region Side Lists -->
          <Grid RowSpacing="5" Margin="0 5 0 0">
            <Grid.RowDefinitions>
              <RowDefinition Height="auto" />
              <RowDefinition Height="auto" />
              <RowDefinition Height="*" />
              <RowDefinition Height="auto" />
              <RowDefinition Height="*" />
              <RowDefinition Height="auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Vertical" Margin="5">

              <!--#region Commander / Partner-->
              <commanderview:CommanderTextView 
                DataContext="{x:Bind ViewModel.DeckViewModel.CommandersViewModel.Commander, Mode=OneWay}"
                CommanderType="Commander"
                CanDrag="True"
                AllowDrop="True"
                HoverPreviewEnabled="True"
                EdhrecButtonClick="{x:Bind ViewModel.DeckViewModel.CommandersViewModel.OpenEdhrecWebsiteCommand, Mode=OneWay}"
                OnDropCopy="{x:Bind ViewModel.DeckViewModel.CommandersViewModel.Commander.ChangeCardCommand, Mode=OneWay}"
                OnDropImport="{x:Bind ViewModel.DeckViewModel.CommandersViewModel.Commander.ImportCardCommand, Mode=OneWay}"
                OnDropBeginMoveFrom="{x:Bind ViewModel.DeckViewModel.CommandersViewModel.Commander.BeginMoveFromCommand, Mode=OneWay}"
                OnDropBeginMoveTo="{x:Bind ViewModel.DeckViewModel.CommandersViewModel.Commander.BeginMoveToCommand, Mode=OneWay}"
                OnDropExecuteMove="{x:Bind ViewModel.DeckViewModel.CommandersViewModel.Commander.ExecuteMoveCommand, Mode=OneWay}"/>
              <commanderview:CommanderTextView 
                DataContext="{x:Bind ViewModel.DeckViewModel.CommandersViewModel.Partner, Mode=OneWay}"
                CommanderType="Partner"
                CanDrag="True"
                AllowDrop="True"
                HoverPreviewEnabled="True"
                EdhrecButtonClick="{x:Bind ViewModel.DeckViewModel.CommandersViewModel.OpenEdhrecWebsiteCommand, Mode=OneWay}"
                OnDropCopy="{x:Bind ViewModel.DeckViewModel.CommandersViewModel.Partner.ChangeCardCommand, Mode=OneWay}"
                OnDropImport="{x:Bind ViewModel.DeckViewModel.CommandersViewModel.Partner.ImportCardCommand, Mode=OneWay}"
                OnDropBeginMoveFrom="{x:Bind ViewModel.DeckViewModel.CommandersViewModel.Partner.BeginMoveFromCommand, Mode=OneWay}"
                OnDropBeginMoveTo="{x:Bind ViewModel.DeckViewModel.CommandersViewModel.Partner.BeginMoveToCommand, Mode=OneWay}"
                OnDropExecuteMove="{x:Bind ViewModel.DeckViewModel.CommandersViewModel.Partner.ExecuteMoveCommand, Mode=OneWay}"/>
            </StackPanel>

            <!--#region Maybelist-->
            <customControls:LinedHeader Grid.Row="1">
              <customControls:LinedHeader.Header>
                <TextBlock Text="Maybe">
                  <TextBlock.ContextFlyout>
                    <MenuFlyout AreOpenCloseAnimationsEnabled="False" Placement="Bottom">
                      <MenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.MaybelistViewModel.ImportCardsCommand, Mode=OneWay}" Text="Import..." />
                      <MenuFlyoutSubItem Text="Export...">
                        <MenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.MaybelistViewModel.ExportCardsCommand, Mode=OneWay}" CommandParameter="Name" Text="By Name" />
                        <MenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.MaybelistViewModel.ExportCardsCommand, Mode=OneWay}" CommandParameter="Id" Text="By Id" />
                      </MenuFlyoutSubItem>
                      <MenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.MaybelistViewModel.ClearCommand, Mode=OneWay}" Text="Clear" Background="IndianRed" />
                    </MenuFlyout>
                  </TextBlock.ContextFlyout>
                </TextBlock>
              </customControls:LinedHeader.Header>
            </customControls:LinedHeader>
            <cardlistview:DeckCardListView
              Grid.Row="2"
              ItemsSource="{x:Bind ViewModel.DeckViewModel.MaybelistViewModel.SortedAndFilteredView.View, Mode=OneWay}"
              Style="{ThemeResource MTGListViewStyle}"
              ItemContainerStyle="{StaticResource MTGListViewItemContainerStyle}"
              SelectionMode="Single"
              CanDragItems="True"
              AllowDrop="True"
              OnDropCopy="{x:Bind ViewModel.DeckViewModel.MaybelistViewModel.AddCardCommand, Mode=OneWay}"
              OnDropImport="{x:Bind ViewModel.DeckViewModel.MaybelistViewModel.ImportCardsCommand, Mode=OneWay}"
              OnDropBeginMoveFrom="{x:Bind ViewModel.DeckViewModel.MaybelistViewModel.BeginMoveFromCommand, Mode=OneWay}"
              OnDropBeginMoveTo="{x:Bind ViewModel.DeckViewModel.MaybelistViewModel.BeginMoveToCommand, Mode=OneWay}"
              OnDropExecuteMove="{x:Bind ViewModel.DeckViewModel.MaybelistViewModel.ExecuteMoveCommand, Mode=OneWay}">
              <cardlistview:DeckCardListView.ItemTemplate>
                <DataTemplate x:DataType="deckcard:DeckCardViewModel">
                  <cardview:DeckEditorCardTextView
                    SetIconVisible="False"
                    TypeLineVisible="False"
                    TagVisible="false"
                    HoverPreviewEnabled="True" />
                </DataTemplate>
              </cardlistview:DeckCardListView.ItemTemplate>
            </cardlistview:DeckCardListView>
            <!--#endregion-->

            <!--#region Wishlist-->
            <customControls:LinedHeader Grid.Row="3">
              <customControls:LinedHeader.Header>
                <TextBlock Text="Wishlist">
                  <TextBlock.ContextFlyout>
                    <MenuFlyout AreOpenCloseAnimationsEnabled="False" Placement="Bottom">
                      <MenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.WishlistViewModel.ImportCardsCommand, Mode=OneWay}" Text="Import..." />
                      <MenuFlyoutSubItem Text="Export...">
                        <MenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.WishlistViewModel.ExportCardsCommand, Mode=OneWay}" CommandParameter="Name" Text="By Name" />
                        <MenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.WishlistViewModel.ExportCardsCommand, Mode=OneWay}" CommandParameter="Id" Text="By Id" />
                      </MenuFlyoutSubItem>
                      <MenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.WishlistViewModel.ClearCommand, Mode=OneWay}" Text="Clear" Background="IndianRed" />
                    </MenuFlyout>
                  </TextBlock.ContextFlyout>
                </TextBlock>
              </customControls:LinedHeader.Header>
            </customControls:LinedHeader>
            <cardlistview:DeckCardListView
              Grid.Row="4"
              ItemsSource="{x:Bind ViewModel.DeckViewModel.WishlistViewModel.SortedAndFilteredView.View, Mode=OneWay}"
              Style="{ThemeResource MTGListViewStyle}"
              ItemContainerStyle="{StaticResource MTGListViewItemContainerStyle}"
              SelectionMode="Single"
              CanDragItems="True"
              AllowDrop="True"
              OnDropCopy="{x:Bind ViewModel.DeckViewModel.WishlistViewModel.AddCardCommand, Mode=OneWay}"
              OnDropImport="{x:Bind ViewModel.DeckViewModel.WishlistViewModel.ImportCardsCommand, Mode=OneWay}"
              OnDropBeginMoveFrom="{x:Bind ViewModel.DeckViewModel.WishlistViewModel.BeginMoveFromCommand, Mode=OneWay}"
              OnDropBeginMoveTo="{x:Bind ViewModel.DeckViewModel.WishlistViewModel.BeginMoveToCommand, Mode=OneWay}"
              OnDropExecuteMove="{x:Bind ViewModel.DeckViewModel.WishlistViewModel.ExecuteMoveCommand, Mode=OneWay}">
              <cardlistview:DeckCardListView.ItemTemplate>
                <DataTemplate x:DataType="deckcard:DeckCardViewModel">
                  <cardview:DeckEditorCardTextView
                    SetIconVisible="False"
                    TypeLineVisible="False"
                    TagVisible="false"
                    HoverPreviewEnabled="True" />
                </DataTemplate>
              </cardlistview:DeckCardListView.ItemTemplate>
            </cardlistview:DeckCardListView>
            <!--#endregion-->

            <!--#region Removelist-->
            <customControls:LinedHeader Grid.Row="5">
              <customControls:LinedHeader.Header>
                <TextBlock Text="Removelist">
                  <TextBlock.ContextFlyout>
                    <MenuFlyout AreOpenCloseAnimationsEnabled="False" Placement="Bottom">
                      <MenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.RemovelistViewModel.ImportCardsCommand, Mode=OneWay}" Text="Import..." />
                      <MenuFlyoutSubItem Text="Export...">
                        <MenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.RemovelistViewModel.ExportCardsCommand, Mode=OneWay}" CommandParameter="Name" Text="By Name" />
                        <MenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.RemovelistViewModel.ExportCardsCommand, Mode=OneWay}" CommandParameter="Id" Text="By Id" />
                      </MenuFlyoutSubItem>
                      <MenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.RemovelistViewModel.ClearCommand, Mode=OneWay}" Text="Clear" Background="IndianRed" />
                    </MenuFlyout>
                  </TextBlock.ContextFlyout>
                </TextBlock>
              </customControls:LinedHeader.Header>
            </customControls:LinedHeader>
            <cardlistview:DeckCardListView
              Grid.Row="6"
              ItemsSource="{x:Bind ViewModel.DeckViewModel.RemovelistViewModel.SortedAndFilteredView.View, Mode=OneWay}"
              Style="{ThemeResource MTGListViewStyle}"
              ItemContainerStyle="{StaticResource MTGListViewItemContainerStyle}"
              SelectionMode="Single"
              CanDragItems="True"
              AllowDrop="True"
              OnDropCopy="{x:Bind ViewModel.DeckViewModel.RemovelistViewModel.AddCardCommand, Mode=OneWay}"
              OnDropImport="{x:Bind ViewModel.DeckViewModel.RemovelistViewModel.ImportCardsCommand, Mode=OneWay}"
              OnDropBeginMoveFrom="{x:Bind ViewModel.DeckViewModel.RemovelistViewModel.BeginMoveFromCommand, Mode=OneWay}"
              OnDropBeginMoveTo="{x:Bind ViewModel.DeckViewModel.RemovelistViewModel.BeginMoveToCommand, Mode=OneWay}"
              OnDropExecuteMove="{x:Bind ViewModel.DeckViewModel.RemovelistViewModel.ExecuteMoveCommand, Mode=OneWay}">
              <cardlistview:DeckCardListView.ItemTemplate>
                <DataTemplate x:DataType="deckcard:DeckCardViewModel">
                  <cardview:DeckEditorCardTextView
                    SetIconVisible="False"
                    TypeLineVisible="False"
                    TagVisible="false"
                    HoverPreviewEnabled="True" />
                </DataTemplate>
              </cardlistview:DeckCardListView.ItemTemplate>
            </cardlistview:DeckCardListView>
            <!--#endregion-->

          </Grid>
          <!--#endregion Side Lists-->

        </TabViewItem>
        <TabViewItem Header="Info" IsClosable="False">
          <ScrollViewer VerticalScrollBarVisibility="auto">
            <StackPanel Orientation="Vertical" Spacing="5" Margin="0 5 0 0">

              <!--#region Side Buttons -->
              <TextBlock Margin="5">
                <Run Text="Price:"/>
                <Run Text="{x:Bind helpers:Format.EuroToString(ViewModel.DeckViewModel.DeckPrice, 0), Mode=OneWay}" FontWeight="Bold"/>
              </TextBlock>
              <Grid Margin="5" ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button HorizontalAlignment="Stretch" Grid.Column="0" Content="Tokens" Command="{x:Bind ViewModel.DeckViewModel.ShowDeckTokensCommand, Mode=OneWay}" Style="{StaticResource PrimaryButtonStyle}"/>
                <Button HorizontalAlignment="Stretch" Grid.Column="1" Content="EDHREC" Command="{x:Bind ViewModel.DeckViewModel.OpenEdhrecSearchWindowCommand, Mode=OneWay}" Style="{StaticResource PrimaryButtonStyle}"/>
                <Button HorizontalAlignment="Stretch" Grid.Column="2" Content="Playtest" Command="{x:Bind ViewModel.DeckViewModel.OpenDeckTestingWindowCommand, Mode=OneWay}" Style="{StaticResource PrimaryButtonStyle}"/>
              </Grid>
              <!--#endregion-->

              <!--#region Charts -->
              <customControls:LinedHeader>
                <customControls:LinedHeader.Header>
                  <TextBlock Text="Mana Curve"/>
                </customControls:LinedHeader.Header>
              </customControls:LinedHeader>
              <controls2:ManaCurveChart Cards="{x:Bind ViewModel.DeckViewModel.ReadOnlyDeckCards, Mode=OneWay}" Height="250"/>
              <customControls:LinedHeader>
                <customControls:LinedHeader.Header>
                  <TextBlock Text="Type Distribution"/>
                </customControls:LinedHeader.Header>
              </customControls:LinedHeader>
              <controls2:CardTypeDistributionChart Cards="{x:Bind ViewModel.DeckViewModel.ReadOnlyDeckCards, Mode=OneWay}" Height="250"/>
              <customControls:LinedHeader>
                <customControls:LinedHeader.Header>
                  <TextBlock Text="Mana Distribution"/>
                </customControls:LinedHeader.Header>
              </customControls:LinedHeader>
              <controls2:ManaDistributionChart Cards="{x:Bind ViewModel.DeckViewModel.ReadOnlyDeckCards, Mode=OneWay}" Height="250"/>
              <!--#endregion Charts-->

            </StackPanel>
          </ScrollViewer>
        </TabViewItem>
      </TabView>
      <!--#endregion-->

      <!--#region Top Bar -->
      <Grid 
        controls:DockPanel.Dock="Top" 
        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
        BorderThickness="0 0 0 1"
        BorderBrush="{ThemeResource RegionColor}">

        <!--#region Commands -->
        <StackPanel Orientation="Horizontal">
          <CommandBar IsOpen="False" DefaultLabelPosition="Right">

            <!--#region File -->
            <AppBarButton Icon="OpenFile" Label="File">
              <AppBarButton.Flyout>
                <MenuFlyout AreOpenCloseAnimationsEnabled="False" Placement="Bottom">
                  <MenuFlyoutItem Command="{x:Bind ViewModel.NewDeckCommand, Mode=OneTime}" Icon="NewFolder" Text="New" KeyboardAcceleratorTextOverride="Ctrl+N"/>
                  <MenuFlyoutItem Command="{x:Bind ViewModel.OpenDeckCommand, Mode=OneTime}" Icon="OpenFile" Text="Open..." KeyboardAcceleratorTextOverride="Ctrl+O"/>
                  <MenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.SaveDeckCommand, Mode=OneWay}" Icon="Save" Text="Save..." KeyboardAcceleratorTextOverride="Ctrl+S"/>
                  <MenuFlyoutSeparator/>
                  <MenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.DeleteDeckCommand, Mode=OneWay}" Background="IndianRed" Icon="Delete" Text="Delete"/>
                </MenuFlyout>
              </AppBarButton.Flyout>
            </AppBarButton>
            <!--#endregion-->

            <!--#region Edit -->
            <AppBarButton Icon="Edit" Label="Edit">
              <AppBarButton.Flyout>
                <MenuFlyout AreOpenCloseAnimationsEnabled="False" Placement="Bottom">
                  <MenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.UndoStack.UndoCommand, Mode=OneWay}" Icon="Undo" Text="Undo" KeyboardAcceleratorTextOverride="Ctrl+Z"/>
                  <MenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.UndoStack.RedoCommand, Mode=OneWay}" Icon="Redo" Text="Redo" KeyboardAcceleratorTextOverride="Ctrl+Y"/>
                </MenuFlyout>
              </AppBarButton.Flyout>
            </AppBarButton>
            <!--#endregion-->

            <AppBarSeparator/>

            <!--#region Zoom -->
            <AppBarButton Icon="ZoomIn" Label="Zoom">
              <AppBarButton.Flyout>
                <Flyout AreOpenCloseAnimationsEnabled="False">
                  <customControls:CardWidthSlider x:Name="CardViewImageSizeSlider" Header="Card size" Width="200" HorizontalAlignment="Left" SnapsTo="Ticks" TickPlacement="Outside"/>
                </Flyout>
              </AppBarButton.Flyout>
            </AppBarButton>
            <!--#endregion-->

            <!--#region Display -->
            <AppBarButton Icon="PreviewLink" ToolTipService.ToolTip="Display" Label="Display">
              <AppBarButton.Flyout>
                <MenuFlyout AreOpenCloseAnimationsEnabled="False" Placement="Bottom">
                  <RadioMenuFlyoutItem IsChecked="{x:Bind DeckCardsViewType, Converter={StaticResource ToStringToBoolConverter}, ConverterParameter=Group, Mode=OneWay}" Command="{x:Bind SetDeckDisplayTypeCommand, Mode=OneWay}" CommandParameter="Group" Text="Groups" GroupName="DeckDisplayCheck" Icon="{ui:SymbolIcon Symbol=Folder}" />
                  <RadioMenuFlyoutItem IsChecked="{x:Bind DeckCardsViewType, Converter={StaticResource ToStringToBoolConverter}, ConverterParameter=Image, Mode=OneWay}" Command="{x:Bind SetDeckDisplayTypeCommand, Mode=OneWay}" CommandParameter="Image" Text="Images" GroupName="DeckDisplayCheck" Icon="{ui:SymbolIcon Symbol=Pictures}" />
                  <RadioMenuFlyoutItem IsChecked="{x:Bind DeckCardsViewType, Converter={StaticResource ToStringToBoolConverter}, ConverterParameter=Text, Mode=OneWay}" Command="{x:Bind SetDeckDisplayTypeCommand, Mode=OneWay}" CommandParameter="Text" Text="Text" GroupName="DeckDisplayCheck" Icon="{ui:SymbolIcon Symbol=List}" />
                </MenuFlyout>
              </AppBarButton.Flyout>
            </AppBarButton>
            <!--#endregion-->

            <!--#region Sort -->
            <AppBarButton Icon="Sort" Label="Sort" AutomationProperties.Name="Order">
              <AppBarButton.Flyout>
                <MenuFlyout AreOpenCloseAnimationsEnabled="False" Placement="Bottom">
                  <RadioMenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.CardSorter.ChangeSortDirectionCommand, Mode=OneWay}" CommandParameter="Ascending" Text="Ascending" GroupName="DirectionGroup" IsChecked="True"/>
                  <RadioMenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.CardSorter.ChangeSortDirectionCommand, Mode=OneWay}" CommandParameter="Descending" Text="Descending" GroupName="DirectionGroup" />
                  <MenuFlyoutSeparator/>
                  <RadioMenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.CardSorter.ChangePrimarySortPropertyCommand, Mode=OneWay}" CommandParameter="CMC" Text="CMC" GroupName="PrimaryDeckSortProperty" IsChecked="True"/>
                  <RadioMenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.CardSorter.ChangePrimarySortPropertyCommand, Mode=OneWay}" CommandParameter="Name"  Text="Name" GroupName="PrimaryDeckSortProperty"/>
                  <RadioMenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.CardSorter.ChangePrimarySortPropertyCommand, Mode=OneWay}" CommandParameter="Color" Text="Color" GroupName="PrimaryDeckSortProperty"/>
                  <RadioMenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.CardSorter.ChangePrimarySortPropertyCommand, Mode=OneWay}" CommandParameter="SpellType" Text="Type" GroupName="PrimaryDeckSortProperty"/>
                  <RadioMenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.CardSorter.ChangePrimarySortPropertyCommand, Mode=OneWay}" CommandParameter="Rarity" Text="Rarity" GroupName="PrimaryDeckSortProperty"/>
                  <RadioMenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.CardSorter.ChangePrimarySortPropertyCommand, Mode=OneWay}" CommandParameter="Set" Text="Set" GroupName="PrimaryDeckSortProperty"/>
                  <RadioMenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.CardSorter.ChangePrimarySortPropertyCommand, Mode=OneWay}" CommandParameter="Count" Text="Count" GroupName="PrimaryDeckSortProperty"/>
                  <RadioMenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.CardSorter.ChangePrimarySortPropertyCommand, Mode=OneWay}" CommandParameter="Price" Text="Price" GroupName="PrimaryDeckSortProperty"/>
                  <MenuFlyoutSeparator />
                  <RadioMenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.CardSorter.ChangeSecondarySortPropertyCommand, Mode=OneWay}" CommandParameter="CMC" Text="CMC" GroupName="SecondaryDeckSortProperty"/>
                  <RadioMenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.CardSorter.ChangeSecondarySortPropertyCommand, Mode=OneWay}" CommandParameter="Name"  Text="Name" GroupName="SecondaryDeckSortProperty" IsChecked="True"/>
                  <RadioMenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.CardSorter.ChangeSecondarySortPropertyCommand, Mode=OneWay}" CommandParameter="Color" Text="Color" GroupName="SecondaryDeckSortProperty"/>
                  <RadioMenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.CardSorter.ChangeSecondarySortPropertyCommand, Mode=OneWay}" CommandParameter="SpellType" Text="Type" GroupName="SecondaryDeckSortProperty"/>
                  <RadioMenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.CardSorter.ChangeSecondarySortPropertyCommand, Mode=OneWay}" CommandParameter="Rarity" Text="Rarity" GroupName="SecondaryDeckSortProperty"/>
                  <RadioMenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.CardSorter.ChangeSecondarySortPropertyCommand, Mode=OneWay}" CommandParameter="Set" Text="Set" GroupName="SecondaryDeckSortProperty"/>
                  <RadioMenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.CardSorter.ChangeSecondarySortPropertyCommand, Mode=OneWay}" CommandParameter="Count" Text="Count" GroupName="SecondaryDeckSortProperty"/>
                  <RadioMenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.CardSorter.ChangeSecondarySortPropertyCommand, Mode=OneWay}" CommandParameter="Price" Text="Price" GroupName="SecondaryDeckSortProperty"/>
                </MenuFlyout>
              </AppBarButton.Flyout>
            </AppBarButton>
            <!--#endregion-->

            <!--#region Filter -->
            <AppBarButton x:Name="DeckFilterAppBarButton" Icon="Filter" Label="Filter" AllowFocusOnInteraction="True">
              <AppBarButton.KeyboardAccelerators>
                <KeyboardAccelerator Key="F" Modifiers="Control" Invoked="FilterKeyboardAccelerator_Invoked"/>
              </AppBarButton.KeyboardAccelerators>
              <AppBarButton.Flyout>
                <Flyout AreOpenCloseAnimationsEnabled="False">
                  <StackPanel Orientation="Vertical" Spacing="10">
                    <TextBox Text="{x:Bind ViewModel.DeckViewModel.CardFilter.NameText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Filter name..."/>
                    <TextBox Text="{x:Bind ViewModel.DeckViewModel.CardFilter.TypeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Filter type..."/>
                    <TextBox Text="{x:Bind ViewModel.DeckViewModel.CardFilter.OracleText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Filter oracle text..."/>
                    <NumberBox PlaceholderText="Filter CMC..." SpinButtonPlacementMode="Hidden" Value="{x:Bind ViewModel.DeckViewModel.CardFilter.Cmc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <StackPanel Orientation="Horizontal" Spacing="5">
                      <ToggleButton Content="W" ToolTipService.ToolTip="White" IsChecked="{x:Bind ViewModel.DeckViewModel.CardFilter.White, Mode=TwoWay}"/>
                      <ToggleButton Content="U" ToolTipService.ToolTip="Blue" IsChecked="{x:Bind ViewModel.DeckViewModel.CardFilter.Blue, Mode=TwoWay}"/>
                      <ToggleButton Content="B" ToolTipService.ToolTip="Black" IsChecked="{x:Bind ViewModel.DeckViewModel.CardFilter.Black, Mode=TwoWay}"/>
                      <ToggleButton Content="R" ToolTipService.ToolTip="Red" IsChecked="{x:Bind ViewModel.DeckViewModel.CardFilter.Red, Mode=TwoWay}"/>
                      <ToggleButton Content="G" ToolTipService.ToolTip="Green" IsChecked="{x:Bind ViewModel.DeckViewModel.CardFilter.Green, Mode=TwoWay}"/>
                      <ToggleButton Content="C" ToolTipService.ToolTip="Colorless" IsChecked="{x:Bind ViewModel.DeckViewModel.CardFilter.Colorless, Mode=TwoWay}"/>
                    </StackPanel>
                    <RadioButtons Header="Color group" MaxColumns="3" SelectedIndex="0">
                      <RadioButton Content="All" GroupName="ColorGroup" IsChecked="{x:Bind ViewModel.DeckViewModel.CardFilter.ColorGroup, Converter={StaticResource CardColorGroupToBoolConverter}, ConverterParameter=All, Mode=OneWay}" Command="{x:Bind ViewModel.DeckViewModel.CardFilter.ChangeColorGroupCommand, Mode=OneWay}" CommandParameter="All"/>
                      <RadioButton Content="Mono" GroupName="ColorGroup" IsChecked="{x:Bind ViewModel.DeckViewModel.CardFilter.ColorGroup, Converter={StaticResource CardColorGroupToBoolConverter}, ConverterParameter=Mono, Mode=OneWay}" Command="{x:Bind ViewModel.DeckViewModel.CardFilter.ChangeColorGroupCommand, Mode=OneWay}" CommandParameter="Mono"/>
                      <RadioButton Content="Multi" GroupName="ColorGroup" IsChecked="{x:Bind ViewModel.DeckViewModel.CardFilter.ColorGroup, Converter={StaticResource CardColorGroupToBoolConverter}, ConverterParameter=Multi, Mode=OneWay}" Command="{x:Bind ViewModel.DeckViewModel.CardFilter.ChangeColorGroupCommand, Mode=OneWay}" CommandParameter="Multi"/>
                    </RadioButtons>
                    <Button Content="Reset filters" Command="{x:Bind ViewModel.DeckViewModel.CardFilter.ResetCommand, Mode=OneWay}"/>
                  </StackPanel>
                </Flyout>
              </AppBarButton.Flyout>
            </AppBarButton>
            <!--#endregion-->

            <!--#region Group View Controls -->
            <AppBarSeparator Visibility="{x:Bind DeckCardsViewType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Group, Mode=OneWay}"/>
            <AppBarButton Visibility="{x:Bind DeckCardsViewType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Group, Mode=OneWay}" Command="{x:Bind ViewModel.DeckViewModel.DeckCardListViewModel.AddGroupCommand, Mode=OneWay}" Icon="Add" Label="Add Group" />
            <!--#endregion-->

            <AppBarElementContainer VerticalAlignment="Center">
              <ProgressRing IsActive="{x:Bind ViewModel.EditorDependencies.Worker.IsBusy, Mode=OneWay}" Margin="5 0 5 0"/>
            </AppBarElementContainer>
          </CommandBar>
        </StackPanel>
        <!--#endregion-->

        <!--#region Deck Info -->
        <StackPanel Orientation="Vertical" VerticalAlignment="Bottom" HorizontalAlignment="Right">
          <TextBlock x:Name="SelectedDeckNameTitle" Text="{x:Bind ViewModel.DeckName, Mode=OneWay}" FontWeight="Bold" HorizontalAlignment="Right"/>
          <TextBlock Text="{x:Bind sys:String.Format('{0} cards', ViewModel.DeckViewModel.DeckSize), Mode=OneWay}" HorizontalAlignment="Right"/>
          <StackPanel.ContextFlyout>
            <MenuFlyout AreOpenCloseAnimationsEnabled="False" Placement="Bottom">
              <MenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.DeckCardListViewModel.ImportCardsCommand, Mode=OneWay}" Text="Import..."/>
              <MenuFlyoutSubItem Text="Export...">
                <MenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.DeckCardListViewModel.ExportCardsCommand, Mode=OneWay}" CommandParameter="Name" Text="By Name"/>
                <MenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.DeckCardListViewModel.ExportCardsCommand, Mode=OneWay}" CommandParameter="Id" Text="By Id"/>
              </MenuFlyoutSubItem>
              <MenuFlyoutItem Command="{x:Bind ViewModel.DeckViewModel.DeckCardListViewModel.ClearCommand, Mode=OneWay}" Text="Clear" Background="IndianRed"/>
            </MenuFlyout>
          </StackPanel.ContextFlyout>
        </StackPanel>
        <!--#endregion-->

      </Grid>
      <!--#endregion-->

      <!--#region Deck Card Views -->
      <Grid controls:DockPanel.Dock="Top">
        
        <!--#region Group View -->
        <ScrollViewer
          Visibility="{x:Bind DeckCardsViewType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Group, Mode=OneWay}"
          VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{x:Bind ViewModel.DeckViewModel.DeckCardListViewModel.GroupViewModels, Mode=OneWay}" Margin="10">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <!--Group template-->
              <DataTemplate x:DataType="cardgroup:DeckCardGroupViewModel">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Stretch">
                  <controls1:CardGroupViewExpander IsExpanded="True" HorizontalAlignment="Stretch">
                    <cardlistview:GroupedDeckCardListItemsRepeater
                      MinHeight="200"
                      Margin="0 0 0 5"
                      ItemsSource="{x:Bind SortedAndFilteredView.View, Mode=OneWay}"
                      AllowDrop="True"
                      CanDragItems="True"
                      OnDropCopy="{x:Bind AddCardCommand, Mode=OneWay}"
                      OnDropImport="{x:Bind ImportCardsCommand, Mode=OneWay}"
                      OnDropBeginMoveFrom="{x:Bind BeginMoveFromCommand, Mode=OneWay}"
                      OnDropBeginMoveTo="{x:Bind BeginMoveToCommand, Mode=OneWay}"
                      OnDropExecuteMove="{x:Bind ExecuteMoveCommand, Mode=OneWay}">
                      <cardlistview:GroupedDeckCardListItemsRepeater.Layout>
                        <UniformGridLayout
                          MinItemWidth="{Binding ElementName=CardViewImageSizeSlider, Path=Value, Mode=OneWay}"
                          ItemsStretch="Fill"/>
                      </cardlistview:GroupedDeckCardListItemsRepeater.Layout>
                      <cardlistview:GroupedDeckCardListItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="deckcard:DeckCardViewModel">
                          <cardview:DeckCardImageViewContainer />
                        </DataTemplate>
                      </cardlistview:GroupedDeckCardListItemsRepeater.ItemTemplate>
                    </cardlistview:GroupedDeckCardListItemsRepeater>
                  </controls1:CardGroupViewExpander>
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
        <!--#endregion-->

        <!--#region Grid View -->
        <cardlistview:DeckCardListItemsRepeater
          Visibility="{x:Bind DeckCardsViewType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Image, Mode=OneWay}"
          ItemsSource="{x:Bind ViewModel.DeckViewModel.DeckCardListViewModel.SortedAndFilteredView.View, Mode=OneWay}"
          AllowDrop="True"
          CanDragItems="True"
          OnDropCopy="{x:Bind ViewModel.DeckViewModel.DeckCardListViewModel.AddCardCommand, Mode=OneWay}"
          OnDropImport="{x:Bind ViewModel.DeckViewModel.DeckCardListViewModel.ImportCardsCommand, Mode=OneWay}"
          OnDropBeginMoveFrom="{x:Bind ViewModel.DeckViewModel.DeckCardListViewModel.BeginMoveFromCommand, Mode=OneWay}"
          OnDropBeginMoveTo="{x:Bind ViewModel.DeckViewModel.DeckCardListViewModel.BeginMoveToCommand, Mode=OneWay}"
          OnDropExecuteMove="{x:Bind ViewModel.DeckViewModel.DeckCardListViewModel.ExecuteMoveCommand, Mode=OneWay}">
          <cardlistview:DeckCardListItemsRepeater.Layout>
            <UniformGridLayout
              MinItemWidth="{Binding ElementName=CardViewImageSizeSlider, Path=Value, Mode=OneWay}"
              ItemsStretch="Fill"/>
          </cardlistview:DeckCardListItemsRepeater.Layout>
          <cardlistview:DeckCardListItemsRepeater.ItemTemplate>
            <DataTemplate x:DataType="deckcard:DeckCardViewModel">
              <cardview:DeckCardImageViewContainer />
            </DataTemplate>
          </cardlistview:DeckCardListItemsRepeater.ItemTemplate>
        </cardlistview:DeckCardListItemsRepeater>
        <!--#endregion-->

        <!--#region List View -->
        <cardlistview:DeckCardListView
          ItemsSource="{x:Bind ViewModel.DeckViewModel.DeckCardListViewModel.SortedAndFilteredView.View, Mode=OneWay}"
          Visibility="{x:Bind DeckCardsViewType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Text, Mode=OneWay}"
          ItemContainerStyle="{StaticResource MTGListViewItemContainerStyle}"
          SelectionMode="Single"
          CanDragItems="True"
          AllowDrop="True"
          OnDropCopy="{x:Bind ViewModel.DeckViewModel.DeckCardListViewModel.AddCardCommand, Mode=OneWay}"
          OnDropImport="{x:Bind ViewModel.DeckViewModel.DeckCardListViewModel.ImportCardsCommand, Mode=OneWay}"
          OnDropBeginMoveFrom="{x:Bind ViewModel.DeckViewModel.DeckCardListViewModel.BeginMoveFromCommand, Mode=OneWay}"
          OnDropBeginMoveTo="{x:Bind ViewModel.DeckViewModel.DeckCardListViewModel.BeginMoveToCommand, Mode=OneWay}"
          OnDropExecuteMove="{x:Bind ViewModel.DeckViewModel.DeckCardListViewModel.ExecuteMoveCommand, Mode=OneWay}">
          <cardlistview:DeckCardListView.ItemTemplate>
            <DataTemplate x:DataType="deckcard:DeckCardViewModel">
              <cardview:DeckEditorCardTextView HoverPreviewEnabled="True" />
            </DataTemplate>
          </cardlistview:DeckCardListView.ItemTemplate>
        </cardlistview:DeckCardListView>
        <!--#endregion-->

      </Grid>
      <!--#endregion-->

    </controls:DockPanel>
  </Grid>
</Page>
