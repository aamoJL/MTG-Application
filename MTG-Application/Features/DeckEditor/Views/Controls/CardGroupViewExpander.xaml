<?xml version="1.0" encoding="utf-8"?>
<controls:CustomExpander
  xmlns:controls="using:MTGApplication.General.Views.Controls"
  x:Class="MTGApplication.Features.DeckEditor.Views.Controls.CardGroupViewExpander"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="using:MTGApplication.Features.DeckEditor.Views.Controls"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:cardgroup="using:MTGApplication.Features.DeckEditor.ViewModels.DeckCardGroup.CardGroup" 
  d:DataContext="{d:DesignInstance Type=cardgroup:DeckCardGroupViewModel}"
  Style="{StaticResource DefaultCustomExpanderStyle}"
  mc:Ignorable="d">

  <controls:CustomExpander.Header>
    <Grid HorizontalAlignment="Stretch">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" MaxWidth="600"/>
      </Grid.ColumnDefinitions>
      <local:CardGroupViewGroupHeader Grid.Column="0" IsExpanded="{x:Bind IsExpanded, Mode=OneWay}" Margin="0 0 0 5">
        <local:CardGroupViewGroupHeader.ContextFlyout>
          <MenuFlyout AreOpenCloseAnimationsEnabled="False" Placement="Bottom">
            <MenuFlyoutItem Command="{Binding RenameGroupCommand, Mode=OneWay}" Text="Rename"/>
            <MenuFlyoutSeparator/>
            <MenuFlyoutItem Command="{Binding DeleteGroupCommand, Mode=OneWay}" Text="Remove" Background="IndianRed"/>
          </MenuFlyout>
        </local:CardGroupViewGroupHeader.ContextFlyout>
      </local:CardGroupViewGroupHeader>
    </Grid>
  </controls:CustomExpander.Header>
</controls:CustomExpander>
