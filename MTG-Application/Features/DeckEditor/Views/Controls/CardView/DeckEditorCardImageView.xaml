<?xml version="1.0" encoding="utf-8"?>
<cardview:DeckEditorCardViewBase
  x:Class="MTGApplication.Features.DeckEditor.Views.Controls.CardView.DeckEditorCardImageView"
  xmlns:cardview="using:MTGApplication.Features.DeckEditor.Views.Controls.CardView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
  xmlns:controls="using:CommunityToolkit.WinUI.Controls"
  xmlns:ui="using:CommunityToolkit.WinUI" 
  xmlns:helpers="using:MTGApplication.General.Views.BindingHelpers" 
  xmlns:controls1="using:MTGApplication.General.Views.Controls.ImageEx"
  xmlns:converters="using:MTGApplication.General.Views.BindingHelpers.Converters"
  xmlns:models="using:MTGApplication.Features.DeckEditor.ViewModels.DeckCard"
  d:DataContext="{d:DesignInstance Type=models:DeckCardViewModel}"
  mc:Ignorable="d">

  <cardview:DeckEditorCardViewBase.Resources>
    <converters:ToStringToBoolConverter x:Key="ToStringToBoolConverter"/>
    <converters:EnumToVisibilityConverter Invert="True" x:Key="EnumToVisibilityConverter"/>
  </cardview:DeckEditorCardViewBase.Resources>
  
  <StackPanel x:Name="DeckGridViewItem" Background="Transparent" Orientation="Vertical" Padding="5">
    <Grid ui:UIElementExtensions.ClipToBounds="True">
      <controls1:ImageEx x:Name="CardImageElement" Style="{StaticResource PlaceholderImageStyle}" Source="{x:Bind SelectedFaceUri, Mode=OneWay}">
        <controls1:ImageEx.ContextFlyout>
          <CommandBarFlyout AlwaysExpanded="True" Placement="RightEdgeAlignedTop">
            <CommandBarFlyout.PrimaryCommands>
              <AppBarButton Command="{x:Bind SwitchFaceImageClickCommand, Mode=OneTime}" Icon="sync" ToolTipService.ToolTip="Flip" IsCompact="True"/>
              <AppBarSeparator />
              <AppBarButton Command="{Binding OpenAPIWebsiteCommand, Mode=OneWay}" Icon="{ui:BitmapIcon Source='/Assets/scryfallIcon.png', ShowAsMonochrome=True}" ToolTipService.ToolTip="{x:Bind Model.Info.ImporterName, Mode=OneWay}" IsCompact="True"/>
              <AppBarButton Command="{Binding OpenCardMarketWebsiteCommand, Mode=OneWay}" Icon="{ui:BitmapIcon Source='/Assets/CardmarketLogo.png', ShowAsMonochrome=True}" ToolTipService.ToolTip="Cardmarket" IsCompact="True"/>
              <AppBarButton Command="{x:Bind DeleteClickCommand, Mode=OneWay}" Background="IndianRed" Icon="delete" ToolTipService.ToolTip="Delete" IsCompact="True"/>
            </CommandBarFlyout.PrimaryCommands>
            <CommandBarFlyout.SecondaryCommands>
              <AppBarButton RequestedTheme="{x:Bind RequestedTheme, Mode=OneWay}" Command="{Binding ChangePrintCommand, Mode=OneWay}" Icon="BrowsePhotos" Label="Show prints..."/>
              <AppBarButton Visibility="{x:Bind TagVisible, Mode=OneWay}" Label="Tag" Icon="{ui:SymbolIcon Symbol=Tag}">
                <AppBarButton.Flyout>
                  <MenuFlyout AreOpenCloseAnimationsEnabled="False">
                    <RadioMenuFlyoutItem GroupName="TagGroup" IsChecked="{x:Bind Model.CardTag, Converter={StaticResource ToStringToBoolConverter}, ConverterParameter=Add, Mode=OneWay}" Text="Add" Command="{x:Bind ChangeTagClickCommand, Mode=OneTime}" CommandParameter="Add"/>
                    <RadioMenuFlyoutItem GroupName="TagGroup" IsChecked="{x:Bind Model.CardTag, Converter={StaticResource ToStringToBoolConverter}, ConverterParameter=Delete, Mode=OneWay}" Text="Delete" Command="{x:Bind ChangeTagClickCommand, Mode=OneTime}" CommandParameter="Delete"/>
                    <RadioMenuFlyoutItem GroupName="TagGroup" IsChecked="{x:Bind Model.CardTag, Converter={StaticResource ToStringToBoolConverter}, ConverterParameter=Move, Mode=OneWay}" Text="Move" Command="{x:Bind ChangeTagClickCommand, Mode=OneTime}" CommandParameter="Move"/>
                    <MenuFlyoutSeparator Visibility="{x:Bind Model.CardTag, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter={x:Null}, Mode=OneWay}"/>
                    <MenuFlyoutItem Text="Clear" Command="{x:Bind ChangeTagClickCommand, Mode=OneTime}" CommandParameter="{x:Null}" Background="{ThemeResource SystemFillColorCriticalBrush}" Visibility="{x:Bind Model.CardTag, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter={x:Null}, Mode=OneWay}"/>
                  </MenuFlyout>
                </AppBarButton.Flyout>
              </AppBarButton>
              <AppBarSeparator/>
              <AppBarElementContainer AllowFocusOnInteraction="True" RequestedTheme="{x:Bind RequestedTheme, Mode=OneWay}">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="Count" Margin="10, 5" VerticalAlignment="Center"/>
                  <NumberBox Value="{x:Bind Model.Count, Mode=OneWay}" VerticalAlignment="Center" Minimum="1" ValueChanged="NumberBox_ValueChanged"/>
                </StackPanel>
              </AppBarElementContainer>
            </CommandBarFlyout.SecondaryCommands>
          </CommandBarFlyout>
        </controls1:ImageEx.ContextFlyout>
      </controls1:ImageEx>
      <Grid Visibility="{x:Bind TagVisible, Mode=OneWay}" HorizontalAlignment="Left" VerticalAlignment="Bottom">
        <Grid x:Name="AddTagElement" x:Load="{x:Bind Model.CardTag, Converter={StaticResource ToStringToBoolConverter}, ConverterParameter=Add, Mode=OneWay}">
          <Rectangle Margin="-30, 5" Width="100" Height="25" Fill="{ThemeResource SystemFillColorSuccessBrush}" RenderTransformOrigin=".5,.5">
            <Rectangle.RenderTransform>
              <RotateTransform Angle="45"/>
            </Rectangle.RenderTransform>
          </Rectangle>
          <FontIcon Glyph="&#xE710;" FontSize="14" Foreground="Black"/>
        </Grid>
        <Grid x:Name="DeleteTagElement" x:Load="{x:Bind Model.CardTag, Converter={StaticResource ToStringToBoolConverter}, ConverterParameter=Delete, Mode=OneWay}">
          <Rectangle Margin="-30, 5" Width="100" Height="25" Fill="{ThemeResource SystemFillColorCriticalBrush}" RenderTransformOrigin=".5,.5">
            <Rectangle.RenderTransform>
              <RotateTransform Angle="45"/>
            </Rectangle.RenderTransform>
          </Rectangle>
          <FontIcon Glyph="&#xE711;" FontSize="14" Foreground="Black"/>
        </Grid>
        <Grid x:Name="MoveTagElement" x:Load="{x:Bind Model.CardTag, Converter={StaticResource ToStringToBoolConverter}, ConverterParameter=Move, Mode=OneWay}">
          <Rectangle Margin="-30, 5" Width="100" Height="25" Fill="{ThemeResource SystemFillColorCautionBrush}" RenderTransformOrigin=".5,.5">
            <Rectangle.RenderTransform>
              <RotateTransform Angle="45"/>
            </Rectangle.RenderTransform>
          </Rectangle>
          <FontIcon Glyph="&#xE895;" FontSize="14" Foreground="Black"/>
        </Grid>
      </Grid>
    </Grid>
    <Grid>
      <TextBlock Text="{x:Bind helpers:Format.EuroToString(Model.Info.Price), Mode=OneWay}" HorizontalAlignment="Right" FontSize="11" Padding="0 0 5 0"/>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
        <TextBlock Text="{x:Bind Model.Count, Mode=OneWay}" Margin="0 5 0 0" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold"/>
      </StackPanel>
    </Grid>
  </StackPanel>
</cardview:DeckEditorCardViewBase>